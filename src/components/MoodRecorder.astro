  class MoodRecorder extends HTMLElement {
    constructor() {
      super();
      
      // UI Elements
      this.uiHeading = this.querySelector('#ui-heading');
      this.uiSubheading = this.querySelector('#ui-subheading');
      
      // Views
      this.recordView = this.querySelector('#record-view');
      this.responseView = this.querySelector('#response-view');
      
      // Record View Elements
      this.btn = this.querySelector('#record-btn');
      this.statusText = this.querySelector('#status-text');
      this.errorMsg = this.querySelector('#error-message');
      
      // Response View Elements
      this.resHeading = this.querySelector('#response-heading');
      this.resContentArea = this.querySelector('#response-content-area');
      this.breathingCircleContainer = this.querySelector('#breathing-circle-container');
      this.distressBox = this.querySelector('#distress-box');
      this.startOverBtn = this.querySelector('#start-over-btn');
      
      // Toast
      this.toastContainer = this.querySelector('#lang-toast');
      this.toastText = this.querySelector('#lang-toast-text');
      this.toastTimeout = null;

      // State
      this.isRecording = false;
      this.mediaRecorder = null;
      this.audioChunks = [];
      this.timerInterval = null;
      this.secondsElapsed = 0;
      this.maxSeconds = 30;
      this.lastDetectedEmotion = "";
      this.currentLang = 'en'; // default
      this.hasErrorState = false;
      
      // Setup Language Bar
      this.setupLanguageBar();
      
      this.btn.addEventListener('click', () => this.toggleRecording());
      this.startOverBtn.addEventListener('click', () => this.resetUI());
      
      // Allow tapping toast to dismiss early
      this.toastContainer.addEventListener('click', () => {
        this.toastContainer.classList.remove('show');
      });
    }

    setupLanguageBar() {
      const savedLang = localStorage.getItem('moodReliefLang');
      if (savedLang && i18n[savedLang]) {
        this.currentLang = savedLang;
      }

      const langBtns = this.querySelectorAll('.lang-btn');
      langBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          this.setLanguage(btn.dataset.lang);
        });
      });

      // Apply initial language (without toast)
      this.setLanguage(this.currentLang, true);
    }

    showToast(msg) {
      if (this.toastTimeout) clearTimeout(this.toastTimeout);
      
      this.toastText.textContent = msg;
      this.toastContainer.classList.add('show');
      
      this.toastTimeout = setTimeout(() => {
        this.toastContainer.classList.remove('show');
      }, 3000);
    }

    setLanguage(langCode, isInitial = false) {
      this.currentLang = langCode;
      localStorage.setItem('moodReliefLang', langCode);

      // Update RTL/LTR layout for Urdu
      document.documentElement.dir = (langCode === 'ur') ? 'rtl' : 'ltr';

      // Update Language Bar UI
      const langBtns = this.querySelectorAll('.lang-btn');
      langBtns.forEach(btn => {
        if (btn.dataset.lang === langCode) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      const t = i18n[langCode];
      
      // Show confirmation toast
      if (!isInitial) {
        this.showToast(t.toast_message);
      }

      // Update Fonts
      document.body.style.fontFamily = t.font;

      // Update UI Text
      this.uiHeading.textContent = t.heading;
      this.uiSubheading.textContent = t.subheading;
      
      // Update footer if it exists
      const footer = document.getElementById('disclaimer-footer');
      if (footer) footer.textContent = t.disclaimer;

      // Update active states
      if (this.isRecording) {
        this.statusText.textContent = t.status_recording.replace('{time}', this.formatTime(this.secondsElapsed));
      } else if (this.statusText.textContent.includes('Processing') || this.statusText.textContent.includes('प्रक्रिया') || this.statusText.textContent.includes('প্রক্রিয়া')) {
        this.statusText.textContent = t.status_processing;
      } else if (!this.hasErrorState) {
        this.statusText.textContent = t.status_start;
      }

      if (this.hasErrorState) {
        this.resHeading.textContent = t.status_error;
        this.startOverBtn.textContent = t.try_again;
      } else {
        if (this.lastDetectedEmotion) {
          this.resHeading.textContent = `${t.response_prefix} ${this.lastDetectedEmotion}`;
        }
        this.startOverBtn.textContent = t.start_over;
      }
    }
    
    getSupportedMimeType() {
      const types = [
        'audio/webm;codecs=opus',
        'audio/webm',
        'audio/mp4' // iOS Safari fallback
      ];
      for (const type of types) {
        if (MediaRecorder.isTypeSupported(type)) {
          return type;
        }
      }
      return '';
    }
    
    showError(msg) {
      this.errorMsg.textContent = msg;
      this.errorMsg.classList.remove('hidden');
    }
    
    hideError() {
      this.errorMsg.classList.add('hidden');
      this.errorMsg.textContent = '';
    }

    async toggleRecording() {
      this.hideError();
      
      if (this.isRecording) {
        this.stopRecording();
      } else {
        await this.startRecording();
      }
    }
    
    formatTime(seconds) {
      const mins = Math.floor(seconds / 60);
      const secs = seconds % 60;
      return `${mins}:${secs.toString().padStart(2, '0')}`;
    }

    async startRecording() {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        
        const mimeType = this.getSupportedMimeType();
        if (!mimeType) {
          this.showError("Your browser does not support audio recording.");
          return;
        }

        this.mediaRecorder = new MediaRecorder(stream, { mimeType });
        this.audioChunks = [];

        this.mediaRecorder.ondataavailable = (e) => {
          if (e.data.size > 0) this.audioChunks.push(e.data);
        };

        this.mediaRecorder.onstop = () => this.handleStop();

        this.mediaRecorder.start();
        this.isRecording = true;
        this.recordView.classList.add('is-recording');
        this.secondsElapsed = 0;
        this.updateTimerDisplay();
        
        this.timerInterval = setInterval(() => {
          this.secondsElapsed++;
          this.updateTimerDisplay();
          
          if (this.secondsElapsed >= this.maxSeconds) {
            this.stopRecording();
          }
        }, 1000);

      } catch (err) {
        console.error("Mic access error:", err);
        if (err.name === 'NotAllowedError' || err.name === 'SecurityError') {
          this.showError("Microphone access is needed. Please enable it in your browser settings and reload.");
        } else {
          this.showError("Could not access microphone: " + err.message);
        }
      }
    }

    updateTimerDisplay() {
      const t = i18n[this.currentLang];
      this.statusText.textContent = t.status_recording.replace('{time}', this.formatTime(this.secondsElapsed));
    }

    stopRecording() {
      if (this.mediaRecorder && this.mediaRecorder.state !== 'inactive') {
        this.mediaRecorder.stop();
        this.mediaRecorder.stream.getTracks().forEach(track => track.stop());
      }
      this.isRecording = false;
      this.recordView.classList.remove('is-recording');
      clearInterval(this.timerInterval);
    }

    async handleStop() {
      const mimeType = this.getSupportedMimeType();
      const audioBlob = new Blob(this.audioChunks, { type: mimeType });
      const t = i18n[this.currentLang];
      
      this.statusText.textContent = t.status_processing;
      
      try {
        const formData = new FormData();
        formData.append('audio', audioBlob);
        // Append the language code to the backend request
        formData.append('language', this.currentLang);

        const response = await fetch('/api/mood', {
          method: 'POST',
          body: formData
        });

        if (!response.ok) {
          throw new Error(`Server returned ${response.status}`);
        }

        const data = await response.json();
        this.renderResponse(data);
        
      } catch (err) {
        console.error("Error posting audio:", err);
        this.hasErrorState = true;
        
        // Global error boundary
        this.recordView.classList.add('hidden');
        this.responseView.classList.remove('hidden');
        this.responseView.classList.add('flex');
        
        this.resHeading.textContent = t.status_error;
        this.resHeading.classList.add('text-red-600');
        
        this.resContentArea.innerHTML = '';
        this.breathingCircleContainer.classList.add('hidden');
        this.distressBox.classList.add('hidden');
        
        this.startOverBtn.textContent = t.try_again;
        this.statusText.textContent = "";
      }
    }

    renderResponse(data) {
      this.hasErrorState = false;
      const t = i18n[this.currentLang];
      this.lastDetectedEmotion = data.emotion;

      this.recordView.classList.add('hidden');
      this.responseView.classList.remove('hidden');
      this.responseView.classList.add('flex');

      this.resHeading.textContent = `${t.response_prefix} ${data.emotion}`;
      this.resHeading.classList.remove('text-red-600');

      this.resContentArea.innerHTML = '';
      this.breathingCircleContainer.classList.add('hidden');
      this.distressBox.classList.add('hidden');

      if (data.responseType === 'breathing') {
        const stepsContainer = document.createElement('div');
        stepsContainer.className = "breathing-steps";
        
        const lines = data.content.split('\n').filter(l => l.trim().length > 0);
        lines.forEach(line => {
          const p = document.createElement('p');
          p.textContent = line;
          stepsContainer.appendChild(p);
        });
        
        const reducedLabel = document.createElement('div');
        reducedLabel.className = 'reduced-motion-steps';
        reducedLabel.textContent = "Inhale (4s) • Hold (1s) • Exhale (4s) • Hold (1s)";
        stepsContainer.appendChild(reducedLabel);

        this.resContentArea.appendChild(stepsContainer);
        this.breathingCircleContainer.classList.remove('hidden');
      } else {
        const textContainer = document.createElement('p');
        textContainer.className = "calming-text";
        textContainer.textContent = data.content;
        this.resContentArea.appendChild(textContainer);
      }

      if (data.includeDistressMessage && data.distressMessage) {
        this.distressBox.textContent = data.distressMessage;
        this.distressBox.classList.remove('hidden');
      }

      this.startOverBtn.textContent = t.start_over;
    }

    resetUI() {
      this.hasErrorState = false;
      this.lastDetectedEmotion = "";
      const t = i18n[this.currentLang];
      
      this.responseView.classList.add('hidden');
      this.responseView.classList.remove('flex');
      
      this.recordView.classList.remove('hidden');
      
      this.statusText.textContent = t.status_start;
      this.hideError();
    }
  }

  customElements.define('mood-recorder', MoodRecorder);
</script>
