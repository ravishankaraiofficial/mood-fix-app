---
// src/components/MoodRecorder.astro
---

<mood-recorder class="w-full flex flex-col items-center">
  <!-- Record View -->
  <div id="record-view" class="w-full flex flex-col items-center">
    <h1 class="text-3xl font-semibold tracking-tight mb-2 text-orange-900">
      Tell me how you’re feeling
    </h1>
    <p class="text-base text-orange-800/80 mb-12">
      Speak for up to 30 seconds. I’ll listen and respond.
    </p>

    <!-- Status Region -->
    <div class="h-12 mb-8 flex items-center justify-center text-center">
      <p id="status-text" class="text-lg font-medium text-orange-900" aria-live="polite">
        Tap the microphone to start.
      </p>
    </div>

    <!-- Record Button -->
    <button 
      id="record-btn" 
      aria-label="Record how you're feeling"
      class="relative flex items-center justify-center w-24 h-24 rounded-full bg-orange-500 hover:bg-orange-600 text-white shadow-soft"
      style="touch-action: manipulation; outline-offset: 4px; transition-property: transform, opacity, background-color; transition-duration: 200ms;"
    >
      <svg id="mic-icon" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" style="transition-property: transform, opacity; transition-duration: 200ms;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
      </svg>
      <svg id="stop-icon" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 absolute opacity-0" style="transition-property: transform, opacity; transition-duration: 200ms;" fill="currentColor" viewBox="0 0 24 24">
        <rect x="6" y="6" width="12" height="12" rx="2" />
      </svg>
      
      <!-- Pulse Ring for recording -->
      <div id="pulse-ring" class="absolute inset-0 rounded-full border-2 border-orange-500 opacity-0 pointer-events-none"></div>
    </button>
    
    <p id="error-message" class="mt-6 text-sm text-red-600 text-center hidden font-medium px-4 py-2 bg-red-50 rounded-md" aria-live="assertive"></p>
  </div>

  <!-- Response View -->
  <div id="response-view" class="w-full hidden flex-col items-center animate-fade-in">
    <h1 id="response-heading" class="text-3xl font-semibold tracking-tight mb-8 text-orange-900" aria-live="polite">
      I hear you’re feeling: …
    </h1>

    <div id="response-content-area" class="w-full mb-8 text-left" aria-live="polite">
      <!-- Breathing or Text injected here -->
    </div>

    <div id="breathing-circle-container" class="hidden mb-8 w-full flex items-center justify-center h-32">
      <div class="w-24 h-24 rounded-full bg-orange-400/30 breathing-circle"></div>
    </div>

    <div id="distress-box" class="hidden w-full mb-8 p-4 bg-orange-100 border border-orange-200 rounded-lg text-orange-900 text-left text-sm">
      <!-- Distress message injected here -->
    </div>

    <button id="start-over-btn" class="px-6 py-3 bg-white border border-orange-200 rounded-full text-orange-900 font-medium shadow-sm hover:bg-orange-50 active:scale-95 transition-transform" style="touch-action: manipulation; outline-offset: 4px;">
      Start over
    </button>
  </div>
</mood-recorder>

<style>
  /* Strict CSS constraints */
  button {
    touch-action: manipulation;
  }
  
  button:focus-visible {
    outline: 3px solid #ea580c; /* Tailwind orange-600 */
    outline-offset: 4px;
  }
  
  /* Tabular nums for timer */
  #status-text {
    font-variant-numeric: tabular-nums;
  }

  /* Pulse animation using only transform and opacity */
  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  /* Recording state classes */
  .is-recording #pulse-ring {
    animation: pulse-ring 1.5s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
  }
  
  .is-recording #mic-icon {
    transform: scale(0.5);
    opacity: 0;
  }
  
  .is-recording #stop-icon {
    opacity: 1;
  }
  
  .is-recording #record-btn {
    transform: scale(0.95);
  }

  /* Breathing Circle Animation (scale 1.0 to 1.4 over 4s, hold 1s, back 4s, pause 1s) = 10s total */
  /*
     0% -> 4s (40%) = scale up
     40% -> 50% (hold) = stay scaled
     50% -> 90% = scale down
     90% -> 100% = pause
  */
  @keyframes breathe {
    0% { transform: scale(1); }
    40% { transform: scale(1.4); }
    50% { transform: scale(1.4); }
    90% { transform: scale(1); }
    100% { transform: scale(1); }
  }
  .breathing-circle {
    animation: breathe 10s linear infinite;
    transform-origin: center;
  }

  /* Text layout utilities for dynamic content */
  .calming-text { font-size: 1.125rem; line-height: 1.6; color: #7c2d12; }
  .breathing-steps { font-size: 1rem; color: #7c2d12; line-height: 1.8; }
  .reduced-motion-steps { display: none; margin-top: 1rem; text-align: center; font-weight: 500; font-size: 1.125rem; color: #ea580c;}

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }

  /* Honor prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .is-recording #pulse-ring {
      animation: none !important;
      display: none !important;
    }
    .breathing-circle {
      animation: none !important;
      display: none !important;
    }
    .reduced-motion-steps {
      display: block !important;
    }
  }
</style>

<script>
  // @ts-nocheck
  class MoodRecorder extends HTMLElement {
    constructor() {
      super();
      
      // Views
      this.recordView = this.querySelector('#record-view');
      this.responseView = this.querySelector('#response-view');
      
      // Record View Elements
      this.btn = this.querySelector('#record-btn');
      this.statusText = this.querySelector('#status-text');
      this.errorMsg = this.querySelector('#error-message');
      
      // Response View Elements
      this.resHeading = this.querySelector('#response-heading');
      this.resContentArea = this.querySelector('#response-content-area');
      this.breathingCircleContainer = this.querySelector('#breathing-circle-container');
      this.distressBox = this.querySelector('#distress-box');
      this.startOverBtn = this.querySelector('#start-over-btn');

      // State
      this.isRecording = false;
      this.mediaRecorder = null;
      this.audioChunks = [];
      this.timerInterval = null;
      this.secondsElapsed = 0;
      this.maxSeconds = 30;
      
      this.btn.addEventListener('click', () => this.toggleRecording());
      this.startOverBtn.addEventListener('click', () => this.resetUI());
    }
    
    getSupportedMimeType() {
      const types = [
        'audio/webm;codecs=opus',
        'audio/webm',
        'audio/mp4' // iOS Safari fallback
      ];
      for (const type of types) {
        if (MediaRecorder.isTypeSupported(type)) {
          return type;
        }
      }
      return '';
    }
    
    showError(msg) {
      this.errorMsg.textContent = msg;
      this.errorMsg.classList.remove('hidden');
    }
    
    hideError() {
      this.errorMsg.classList.add('hidden');
      this.errorMsg.textContent = '';
    }

    async toggleRecording() {
      this.hideError();
      
      if (this.isRecording) {
        this.stopRecording();
      } else {
        await this.startRecording();
      }
    }
    
    formatTime(seconds) {
      const mins = Math.floor(seconds / 60);
      const secs = seconds % 60;
      return `${mins}:${secs.toString().padStart(2, '0')}`;
    }

    async startRecording() {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        
        const mimeType = this.getSupportedMimeType();
        if (!mimeType) {
          this.showError("Your browser does not support audio recording.");
          return;
        }

        this.mediaRecorder = new MediaRecorder(stream, { mimeType });
        this.audioChunks = [];

        this.mediaRecorder.ondataavailable = (e) => {
          if (e.data.size > 0) this.audioChunks.push(e.data);
        };

        this.mediaRecorder.onstop = () => this.handleStop();

        this.mediaRecorder.start();
        this.isRecording = true;
        this.recordView.classList.add('is-recording');
        this.secondsElapsed = 0;
        this.updateTimerDisplay();
        
        this.timerInterval = setInterval(() => {
          this.secondsElapsed++;
          this.updateTimerDisplay();
          
          if (this.secondsElapsed >= this.maxSeconds) {
            this.stopRecording();
          }
        }, 1000);

      } catch (err) {
        console.error("Mic access error:", err);
        if (err.name === 'NotAllowedError' || err.name === 'SecurityError') {
          this.showError("Microphone access is needed. Please enable it in your browser settings and reload.");
        } else {
          this.showError("Could not access microphone: " + err.message);
        }
      }
    }

    updateTimerDisplay() {
      this.statusText.textContent = `Recording… ${this.formatTime(this.secondsElapsed)}`;
    }

    stopRecording() {
      if (this.mediaRecorder && this.mediaRecorder.state !== 'inactive') {
        this.mediaRecorder.stop();
        // Also stop all mic tracks
        this.mediaRecorder.stream.getTracks().forEach(track => track.stop());
      }
      this.isRecording = false;
      this.recordView.classList.remove('is-recording');
      clearInterval(this.timerInterval);
      // 6. Ensure Start Over button says Start Over
      this.startOverBtn.textContent = "Start over";
    }

    async handleStop() {
      const mimeType = this.getSupportedMimeType();
      const audioBlob = new Blob(this.audioChunks, { type: mimeType });
      
      this.statusText.textContent = "Processing…";
      
      try {
        const formData = new FormData();
        formData.append('audio', audioBlob);

        const response = await fetch('/api/mood', {
          method: 'POST',
          body: formData
        });

        if (!response.ok) {
          throw new Error(`Server returned ${response.status}`);
        }

        const data = await response.json();
        this.renderResponse(data);
        
      } catch (err) {
        console.error("Error posting audio:", err);
        
        // Global error boundary: transition to response view with error state
        this.recordView.classList.add('hidden');
        this.responseView.classList.remove('hidden');
        this.responseView.classList.add('flex');
        
        this.resHeading.textContent = "Something went wrong. Please try again.";
        this.resHeading.classList.add('text-red-600');
        
        this.resContentArea.innerHTML = '';
        this.breathingCircleContainer.classList.add('hidden');
        this.distressBox.classList.add('hidden');
        
        this.startOverBtn.textContent = "Try again";
        this.statusText.textContent = "";
      }
    }

    renderResponse(data) {
      // 1. Hide record view, show response view
      this.recordView.classList.add('hidden');
      this.responseView.classList.remove('hidden');
      this.responseView.classList.add('flex');

      // 2. Set Heading
      this.resHeading.textContent = `I hear you’re feeling: ${data.emotion}`;
      this.resHeading.classList.remove('text-red-600');

      // 3. Clear previous content
      this.resContentArea.innerHTML = '';
      this.breathingCircleContainer.classList.add('hidden');
      this.distressBox.classList.add('hidden');

      // 4. Render main content based on type
      if (data.responseType === 'breathing') {
        // Steps
        const stepsContainer = document.createElement('div');
        stepsContainer.className = "breathing-steps";
        // Convert plain text steps to HTML lines
        const lines = data.content.split('\n').filter(l => l.trim().length > 0);
        lines.forEach(line => {
          const p = document.createElement('p');
          p.textContent = line;
          stepsContainer.appendChild(p);
        });
        
        // Reduced motion fallback labels
        const reducedLabel = document.createElement('div');
        reducedLabel.className = 'reduced-motion-steps';
        reducedLabel.textContent = "Inhale (4s) • Hold (1s) • Exhale (4s) • Hold (1s)";
        stepsContainer.appendChild(reducedLabel);

        this.resContentArea.appendChild(stepsContainer);

        // Show circle
        this.breathingCircleContainer.classList.remove('hidden');
      } else {
        // Calming text
        const textContainer = document.createElement('p');
        textContainer.className = "calming-text";
        textContainer.textContent = data.content;
        this.resContentArea.appendChild(textContainer);
      }

      // 5. Distress Message
      if (data.includeDistressMessage && data.distressMessage) {
        this.distressBox.textContent = data.distressMessage;
        this.distressBox.classList.remove('hidden');
      }
    }

    resetUI() {
      // Hide response, show record
      this.responseView.classList.add('hidden');
      this.responseView.classList.remove('flex');
      
      this.recordView.classList.remove('hidden');
      
      // Reset statuses
      this.statusText.textContent = "Tap the microphone to start.";
      this.hideError();
    }
  }

  customElements.define('mood-recorder', MoodRecorder);
</script>
