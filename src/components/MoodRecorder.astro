---
// src/components/MoodRecorder.astro
---

<mood-recorder class="w-full flex flex-col items-center pt-2">
  <!-- Language Bar -->
  <nav id="lang-bar" class="w-full flex flex-wrap justify-center gap-x-3 gap-y-2 mb-10 text-sm text-orange-900/60 transition-all" aria-label="Language selection">
    <!-- Buttons dynamically inserted by JS, but hardcoded here for layout stability -->
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to English" data-lang="en">English</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Hindi" data-lang="hi">हिन्दी</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Bengali" data-lang="bn">বাংলা</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Telugu" data-lang="te">తెలుగు</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Marathi" data-lang="mr">मराठी</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Tamil" data-lang="ta">தமிழ்</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Gujarati" data-lang="gu">ગુજરાતી</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Urdu" data-lang="ur">اردو</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Kannada" data-lang="kn">ಕನ್ನಡ</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Odia" data-lang="or">ଓଡ଼ିଆ</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Malayalam" data-lang="ml">മലയാളം</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Punjabi" data-lang="pa">ਪੰਜਾਬੀ</button>
    <button type="button" class="lang-btn hover:font-bold hover:text-orange-900 focus-visible:font-bold focus-visible:text-orange-900 transition-all" aria-label="Switch to Assamese" data-lang="as">অসমীয়া</button>
  </nav>

  <!-- Record View -->
  <div id="record-view" class="w-full flex flex-col items-center">
    <h1 id="ui-heading" class="text-3xl font-semibold tracking-tight mb-2 text-orange-900 transition-all duration-300">
      Tell me how you’re feeling
    </h1>
    <p id="ui-subheading" class="text-base text-orange-800/80 mb-12 transition-all duration-300">
      Speak for up to 30 seconds. I’ll listen and respond.
    </p>

    <!-- Status Region -->
    <div class="h-12 mb-8 flex items-center justify-center text-center">
      <p id="status-text" class="text-lg font-medium text-orange-900 transition-all duration-300" aria-live="polite">
        Tap the microphone to start.
      </p>
    </div>

    <!-- Record Button -->
    <button 
      id="record-btn" 
      aria-label="Record how you're feeling"
      class="relative flex items-center justify-center w-24 h-24 rounded-full bg-orange-500 hover:bg-orange-600 text-white shadow-soft"
      style="touch-action: manipulation; outline-offset: 4px; transition-property: transform, opacity, background-color; transition-duration: 200ms;"
    >
      <svg id="mic-icon" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" style="transition-property: transform, opacity; transition-duration: 200ms;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
      </svg>
      <svg id="stop-icon" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 absolute opacity-0" style="transition-property: transform, opacity; transition-duration: 200ms;" fill="currentColor" viewBox="0 0 24 24">
        <rect x="6" y="6" width="12" height="12" rx="2" />
      </svg>
      
      <!-- Pulse Ring for recording -->
      <div id="pulse-ring" class="absolute inset-0 rounded-full border-2 border-orange-500 opacity-0 pointer-events-none"></div>
    </button>
    
    <p id="error-message" class="mt-6 text-sm text-red-600 text-center hidden font-medium px-4 py-2 bg-red-50 rounded-md transition-all duration-300" aria-live="assertive"></p>
  </div>

  <!-- Response View -->
  <div id="response-view" class="w-full hidden flex-col items-center animate-fade-in">
    <h1 id="response-heading" class="text-3xl font-semibold tracking-tight mb-8 text-orange-900 transition-all duration-300" aria-live="polite">
      I hear you’re feeling: …
    </h1>

    <div id="response-content-area" class="w-full mb-8 text-left transition-all duration-300" aria-live="polite">
      <!-- Breathing or Text injected here -->
    </div>

    <div id="breathing-circle-container" class="hidden mb-8 w-full flex items-center justify-center h-32">
      <div class="w-24 h-24 rounded-full bg-orange-400/30 breathing-circle"></div>
    </div>

    <div id="distress-box" class="hidden w-full mb-8 p-4 bg-orange-100 border border-orange-200 rounded-lg text-orange-900 text-left text-sm transition-all duration-300">
      <!-- Distress message injected here -->
    </div>

    <button id="start-over-btn" class="px-6 py-3 bg-white border border-orange-200 rounded-full text-orange-900 font-medium shadow-sm hover:bg-orange-50 active:scale-95 transition-transform" style="touch-action: manipulation; outline-offset: 4px;">
      Start over
    </button>
  </div>
  
  <!-- Language Confirmation Toast -->
  <div id="lang-toast" class="fixed bottom-24 left-1/2 -translate-x-1/2 bg-orange-900/95 backdrop-blur-sm text-orange-50 px-6 py-3 rounded-full text-sm font-medium shadow-xl pointer-events-none transition-all duration-300 opacity-0 translate-y-4 z-50 flex items-center gap-2" aria-live="polite" role="status">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-orange-300" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>
    <span id="lang-toast-text"></span>
  </div>
</mood-recorder>

<style>
  /* Strict CSS constraints */
  button {
    touch-action: manipulation;
  }
  
  button:focus-visible {
    outline: 3px solid #ea580c;
    outline-offset: 4px;
  }
  
  /* Language bar styling */
  .lang-btn {
    transition-property: font-weight, opacity;
    transition-duration: 200ms;
  }
  .lang-btn.active {
    font-weight: 700;
    color: #7c2d12;
    text-decoration: underline;
    text-decoration-color: #ea580c;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }
  
  /* Toast Animation */
  #lang-toast.show {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  
  /* Tabular nums for timer */
  #status-text {
    font-variant-numeric: tabular-nums;
  }

  /* Pulse animation */
  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  /* Recording state classes */
  .is-recording #pulse-ring {
    animation: pulse-ring 1.5s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
  }
  
  .is-recording #mic-icon {
    transform: scale(0.5);
    opacity: 0;
  }
  
  .is-recording #stop-icon {
    opacity: 1;
  }
  
  .is-recording #record-btn {
    transform: scale(0.95);
  }

  /* Breathing Circle Animation */
  @keyframes breathe {
    0% { transform: scale(1); }
    40% { transform: scale(1.4); }
    50% { transform: scale(1.4); }
    90% { transform: scale(1); }
    100% { transform: scale(1); }
  }
  .breathing-circle {
    animation: breathe 10s linear infinite;
    transform-origin: center;
  }

  /* Text layout utilities for dynamic content */
  .calming-text { font-size: 1.125rem; line-height: 1.6; color: #7c2d12; }
  .breathing-steps { font-size: 1rem; color: #7c2d12; line-height: 1.8; }
  .reduced-motion-steps { display: none; margin-top: 1rem; text-align: center; font-weight: 500; font-size: 1.125rem; color: #ea580c;}

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }

  /* Honor prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .is-recording #pulse-ring {
      animation: none !important;
      display: none !important;
    }
    .breathing-circle {
      animation: none !important;
      display: none !important;
    }
    .reduced-motion-steps {
      display: block !important;
    }
    #lang-toast {
      transition: opacity 300ms !important;
      transform: translate(-50%, 0) !important;
    }
    #lang-toast.show {
      opacity: 1 !important;
    }
  }
</style>

