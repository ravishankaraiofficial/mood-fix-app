---
// Homepage
import '../styles/global.css';
import MoodRecorder from '../components/MoodRecorder.astro';
---
<html lang="en" style="color-scheme: light;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fff7ed" />
    <title>Mood Relief App</title>
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center p-6 bg-orange-50 text-ink antialiased pb-20">
    <main class="w-full max-w-[375px] mx-auto flex flex-col items-center text-center">
      <MoodRecorder />
    </main>

    <footer class="fixed bottom-0 left-0 w-full p-4 text-center text-xs text-orange-900/60 bg-orange-50/90 backdrop-blur-sm z-50 border-t border-orange-900/10">
      This is a calming tool, not medical advice. If you are in crisis, please reach out to someone you trust or a local helpline.
    </footer>
  </body>
</html>
